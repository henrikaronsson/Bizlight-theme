{
  "name": "bizlight-theme",
  "version": "1.0.0",
  "description": "Bizlight Bootstrap 3 theme with a modern npm-based development toolchain.",
  "private": true,
  "scripts": {
    "build:css": "sass sass/app.scss css/app.css --style=compressed --quiet",
    "watch:css": "sass --watch sass/app.scss:css/app.css --quiet",
    "serve": "live-server --port=8000",
    "dev": "run-p watch:css serve",
    "build": "npm run build:css"
  },
  "engines": {
    "node": ">=18"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "dependencies": {
    "bootstrap-sass": "^3.4.3",
    "font-awesome": "^4.7.0",
    "jquery": "^3.7.1"
  },
  "devDependencies": {
    "live-server": "^1.2.2",
    "npm-run-all": "^4.1.5",
    "sass": "^1.77.0"
  }
}
